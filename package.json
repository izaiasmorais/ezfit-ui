{
	"name": "@ezfit/ui",
	"version": "1.2.0",
	"description": "EZFIT Design System - biblioteca de componentes React para dashboards de saude, dieta e treino",
	"type": "module",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/izaiasmorais/ezfit-ui.git"
	},
	"sideEffects": [
		"**/*.css"
	],
	"files": [
		"dist"
	],
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./styles.css": "./dist/styles.css"
	},
	"scripts": {
		"dev": "storybook dev -p 6006",
		"build": "tsc --noEmit && vite build",
		"build-storybook": "storybook build",
		"typecheck": "tsc --noEmit",
		"check": "biome check",
		"fix": "biome check --write",
		"lint": "biome lint",
		"format": "biome format --write"
	},
	"publishConfig": {
		"access": "public"
	},
	"peerDependencies": {
		"react": ">=18",
		"react-dom": ">=18"
	},
	"dependencies": {
		"@hugeicons/core-free-icons": "^4.2.1",
		"@hugeicons/react": "^1.1.7",
		"@radix-ui/react-accordion": "^1.2.11",
		"@radix-ui/react-checkbox": "^1.3.2",
		"@radix-ui/react-dialog": "^1.1.14",
		"@radix-ui/react-dropdown-menu": "^2.1.15",
		"@radix-ui/react-label": "^2.1.7",
		"@radix-ui/react-popover": "^1.1.14",
		"@radix-ui/react-radio-group": "^1.3.7",
		"@radix-ui/react-select": "^2.2.5",
		"@radix-ui/react-slider": "^1.3.5",
		"@radix-ui/react-switch": "^1.2.5",
		"@radix-ui/react-tabs": "^1.1.12",
		"@radix-ui/react-toast": "^1.2.14",
		"@radix-ui/react-tooltip": "^1.2.7",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"recharts": "^2.15.4",
		"tailwind-merge": "^3.3.1"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.0",
		"@storybook/addon-a11y": "^8.6.14",
		"@storybook/addon-essentials": "^8.6.14",
		"@storybook/addon-interactions": "^8.6.14",
		"@storybook/addon-themes": "^8.6.14",
		"@storybook/react": "^8.6.14",
		"@storybook/react-vite": "^8.6.14",
		"@storybook/test": "^8.6.14",
		"@tailwindcss/vite": "^4.1.13",
		"@types/react": "^18.3.23",
		"@types/react-dom": "^18.3.7",
		"@vitejs/plugin-react": "^4.7.0",
		"ajv": "^8.20.0",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"storybook": "^8.6.14",
		"tailwindcss": "^4.1.13",
		"typescript": "^5.9.2",
		"vite": "^6.3.5",
		"vite-plugin-dts": "^4.5.4"
	}
}
